{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.meetcal.app/:path*"
      "source": "/features",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/index.html"
    },
    {
      "source": "/terms",
      "destination": "/index.html"
    },
    {
      "source": "/comp-data",
      "destination": "/index.html"
    },
    {
      "source": "/qualifying-totals",
      "destination": "/index.html"
    },
    {
      "source": "/standards",
      "destination": "/index.html"
    },
    {
      "source": "/records",
      "destination": "/index.html"
    },
    {
      "source": "/results",
      "destination": "/index.html"
    },
    {
      "source": "/rankings",
      "destination": "/index.html"
    }
  ]
}
